# Storsafe - environment variables template
# Copy this file to `.env` (same folder) and fill in values.
# Never commit `.env`.

# AI providers (if used by scripts)
OPENAI_API_KEY=

# Google service account credentials (choose ONE approach)
# Option A (recommended): point to a JSON file path
GOOGLE_APPLICATION_CREDENTIALS=
# Option B: same as above, alternate variable name used by some scripts
SERVICE_ACCOUNT_FILE=
# Option C: paste the full service account JSON as a single-line string
SERVICE_ACCOUNT_JSON=
